{
  "manifest_version": 2,
  "name": "已关闭网页查看器",
  "version": "1.0",
  "description": "查看被关闭的网页，按时间倒序排列",
  "author": "rouwanzi77",
  "homepage_url": "https://github.com/rouwanzi77/closed_webpage",
  "browser_specific_settings": {
    "gecko": {
      "id": "closed-tabs-viewer@rouwanzi77.github.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": [],
        "telemetry": false
      }
    }
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "已关闭网页查看器"
  },
  "background": {
    "scripts": ["background.js"]
  }
}
